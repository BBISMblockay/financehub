<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Statement Aging</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/papaparse@5.4.1/papaparse.min.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root { color-scheme: light; }
    html, body { height: 100%; }
    body {
      font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #f5f7fb;
      color: #0f172a;
    }
    .mono { font-variant-numeric: tabular-nums; font-feature-settings: "tnum" 1; }
    .shell { max-width: 1500px; margin: 0 auto; padding: 22px; }
    .card {
      background: #fff;
      border: 1px solid #e5e7eb;
      border-radius: 22px;
      box-shadow: 0 1px 2px rgba(15,23,42,.04), 0 10px 24px rgba(15,23,42,.04);
    }
    .input, .select {
      width: 100%;
      border-radius: 14px;
      border: 1px solid #d7dee8;
      background: #fff;
      padding: .76rem .92rem;
      font-size: .92rem;
      outline: none;
      transition: .18s ease;
    }
    .input:focus, .select:focus {
      border-color: #0f172a;
      box-shadow: 0 0 0 3px rgba(15,23,42,.08);
    }
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 14px;
      padding: .78rem 1rem;
      font-weight: 700;
      font-size: .92rem;
      transition: .18s ease;
      border: 1px solid #d7dee8;
      background: #fff;
      color: #0f172a;
    }
    .btn:hover { transform: translateY(-1px); }
    .btn-primary { background: #0f172a; color: #fff; border-color: #0f172a; }
    .segmented {
      display: inline-flex;
      gap: 4px;
      padding: 4px;
      border-radius: 999px;
      border: 1px solid #e2e8f0;
      background: #f8fafc;
    }
    .segmented button {
      border: 0;
      background: transparent;
      color: #475569;
      border-radius: 999px;
      padding: .45rem .85rem;
      font-size: .8rem;
      font-weight: 700;
      cursor: pointer;
    }
    .segmented button.active { background: #0f172a; color: #fff; }
    .kpi {
      border: 1px solid #e5e7eb;
      border-radius: 18px;
      padding: 14px 16px;
      background: linear-gradient(180deg, #fff 0%, #fbfdff 100%);
      min-height: 98px;
    }
    .kpi-label {
      font-size: .69rem;
      text-transform: uppercase;
      letter-spacing: .06em;
      color: #64748b;
      font-weight: 800;
    }
    .kpi-value {
      margin-top: 8px;
      font-size: 1.55rem;
      line-height: 1.05;
      font-weight: 800;
      color: #0f172a;
    }
    .kpi-sub { margin-top: 6px; font-size: .75rem; color: #64748b; }
    .section-title { font-size: 1rem; font-weight: 800; color: #0f172a; }
    .section-sub { margin-top: 2px; font-size: .82rem; color: #64748b; }
    .mini-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px; }
    .mini-card {
      border: 1px solid #e5e7eb;
      border-radius: 16px;
      padding: 12px;
      background: #fff;
    }
    .mini-card .label {
      font-size: .68rem;
      text-transform: uppercase;
      letter-spacing: .06em;
      color: #64748b;
      font-weight: 800;
    }
    .mini-card .value {
      margin-top: 8px;
      font-size: 1.08rem;
      font-weight: 800;
      color: #0f172a;
    }
    .list-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 10px 0;
      border-bottom: 1px solid #eef2f7;
    }
    .list-row:last-child { border-bottom: 0; }
    .bar-track {
      height: 8px;
      border-radius: 999px;
      background: #eef2f7;
      overflow: hidden;
      margin-top: 8px;
    }
    .bar-fill {
      display: block;
      height: 100%;
      border-radius: 999px;
      background: #0f172a;
    }
    .table-wrap {
      overflow: auto;
      border: 1px solid #e5e7eb;
      border-radius: 18px;
      background: #fff;
    }
    table { width: 100%; border-collapse: separate; border-spacing: 0; }
    thead th {
      position: sticky;
      top: 0;
      z-index: 2;
      background: #f8fafc;
      color: #64748b;
      font-size: .72rem;
      text-transform: uppercase;
      letter-spacing: .05em;
      font-weight: 800;
      padding: .82rem .85rem;
      border-bottom: 1px solid #e5e7eb;
      text-align: left;
      white-space: nowrap;
    }
    tbody td {
      padding: .82rem .85rem;
      border-bottom: 1px solid #f1f5f9;
      font-size: .89rem;
      vertical-align: middle;
      color: #0f172a;
    }
    tbody tr:hover td { background: #fafcff; }
    .right { text-align: right; }
    .muted { color: #64748b; }
    .badge {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      padding: .24rem .55rem;
      font-size: .71rem;
      font-weight: 700;
      border: 1px solid transparent;
      white-space: nowrap;
    }
    .badge-paid { background: #ecfdf5; color: #166534; border-color: #bbf7d0; }
    .badge-open { background: #fff7ed; color: #9a3412; border-color: #fed7aa; }
    .badge-closed { background: #f8fafc; color: #475569; border-color: #cbd5e1; }
    .badge-fulfilled { background: #eff6ff; color: #1d4ed8; border-color: #bfdbfe; }
    .badge-unfulfilled { background: #fef2f2; color: #b91c1c; border-color: #fecaca; }
    .w-customer { min-width: 220px; }
    .w-email { min-width: 180px; max-width: 240px; }
    .w-small { min-width: 84px; }
    .w-money { min-width: 112px; }
    details summary { list-style: none; cursor: pointer; }
    details summary::-webkit-details-marker { display: none; }
    @media (max-width: 1100px) {
      .shell { padding: 14px; }
      .mini-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body class="min-h-full">
  <div class="shell">
    <div class="space-y-5">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">Statement aging</h1>
          <p class="mt-2 max-w-3xl text-sm text-slate-600">Simple view of open customer balances and aging.</p>
        </div>
        <div class="segmented">
          <button id="viewRollupBtn" class="active">Rollup</button>
          <button id="viewOrdersBtn">Orders</button>
        </div>
      </div>

      <div class="card p-4 lg:p-5">
        <div class="grid grid-cols-1 gap-4 lg:grid-cols-12">
          <div class="lg:col-span-3">
            <label class="mb-2 block text-sm font-semibold text-slate-700">As of</label>
            <input id="asOfDate" type="date" class="input" />
          </div>
          <div class="lg:col-span-3">
            <label class="mb-2 block text-sm font-semibold text-slate-700">Date field</label>
            <select id="dateField" class="select">
              <option value="DAY Order Date">DAY Order Date</option>
              <option value="auto">Auto detect</option>
            </select>
          </div>
          <div class="lg:col-span-3 flex items-end gap-3">
            <button id="refreshBtn" class="btn btn-primary w-full">Refresh</button>
          </div>
          <div class="lg:col-span-3 flex items-end gap-3">
            <button id="exportBtn" class="btn w-full">Export rollup</button>
          </div>
          <div id="statusText" class="lg:col-span-12 text-xs text-slate-500">Waiting for data.</div>
        </div>
      </div>

      <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-6">
        <div class="kpi"><div class="kpi-label">Sales</div><div id="kpiNetSales" class="kpi-value mono">$0.00</div><div class="kpi-sub">Filtered sales</div></div>
        <div class="kpi"><div class="kpi-label">Open</div><div id="kpiOpenBalance" class="kpi-value mono">$0.00</div><div class="kpi-sub">Current balance</div></div>
        <div class="kpi"><div class="kpi-label">Paid</div><div id="kpiPaidSales" class="kpi-value mono">$0.00</div><div class="kpi-sub">Settled rows</div></div>
        <div class="kpi"><div class="kpi-label">Customers</div><div id="kpiCustomers" class="kpi-value mono">0</div><div class="kpi-sub">With open balance</div></div>
        <div class="kpi"><div class="kpi-label">0–30</div><div id="kpi0to30" class="kpi-value mono">$0.00</div><div class="kpi-sub">Recent aging</div></div>
        <div class="kpi"><div class="kpi-label">31+</div><div id="kpi31plus" class="kpi-value mono">$0.00</div><div class="kpi-sub">Older aging</div></div>
      </div>

      <div class="card p-4 lg:p-5">
        <div class="grid grid-cols-1 gap-4 lg:grid-cols-12">
          <div class="lg:col-span-4">
            <label class="mb-2 block text-sm font-semibold text-slate-700">Search</label>
            <input id="searchInput" class="input" placeholder="Customer, email, order..." />
          </div>
          <div class="lg:col-span-2">
            <label class="mb-2 block text-sm font-semibold text-slate-700">Start</label>
            <input id="startDate" type="date" class="input" />
          </div>
          <div class="lg:col-span-2">
            <label class="mb-2 block text-sm font-semibold text-slate-700">End</label>
            <input id="endDate" type="date" class="input" />
          </div>
          <div class="lg:col-span-2">
            <label class="mb-2 block text-sm font-semibold text-slate-700">Status</label>
            <select id="financialFilter" class="select">
              <option value="">All</option>
              <option value="open">Open only</option>
              <option value="paid">Paid only</option>
              <option value="pending">Pending only</option>
              <option value="authorized">Authorized only</option>
              <option value="voided">Voided only</option>
            </select>
          </div>
          <div class="lg:col-span-2">
            <label class="mb-2 block text-sm font-semibold text-slate-700">Aging</label>
            <select id="agingFilter" class="select">
              <option value="">All</option>
              <option value="0-30">0–30</option>
              <option value="31-60">31–60</option>
              <option value="61-90">61–90</option>
              <option value="90+">90+</option>
              <option value="paid">Paid</option>
            </select>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 gap-5 xl:grid-cols-12">
        <div class="xl:col-span-9 space-y-5">
          <div class="card p-4 lg:p-5">
            <div class="flex items-start justify-between gap-3">
              <div>
                <div id="mainTableTitle" class="section-title">Customer rollup</div>
                <div id="mainTableSub" class="section-sub">Who owes and how old it is.</div>
              </div>
              <div class="text-xs text-slate-500"><span id="rowCount">0</span> rows</div>
            </div>
            <div class="mt-4 table-wrap max-h-[700px]">
              <table>
                <thead id="mainHead"></thead>
                <tbody id="mainBody"></tbody>
              </table>
            </div>
          </div>

          <details class="card p-4 lg:p-5" id="detailPanel">
            <summary class="flex items-center justify-between gap-3">
              <div>
                <div class="section-title">Order detail</div>
                <div class="section-sub">Underlying rows.</div>
              </div>
              <div class="text-xs font-bold text-slate-500">Expand</div>
            </summary>
            <div class="mt-4 table-wrap max-h-[520px]">
              <table>
                <thead id="detailHead"></thead>
                <tbody id="detailBody"></tbody>
              </table>
            </div>
          </details>
        </div>

        <div class="xl:col-span-3 space-y-5">
          <div class="card p-4 lg:p-5">
            <div class="section-title">Summary</div>
            <div class="mini-grid mt-4" id="companySummary"></div>
          </div>

          <div class="card p-4 lg:p-5">
            <div class="section-title">Top open</div>
            <div class="section-sub">Largest balances.</div>
            <div id="topCustomers" class="mt-4"></div>
          </div>

          <div class="card p-4 lg:p-5">
            <div class="section-title">Aging</div>
            <div id="agingCards" class="mt-4"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const CSV_SOURCES = [
      'https://docs.google.com/spreadsheets/d/e/2PACX-1vStgtzXpQpW_9oWh4QC2NOoO7F9L0fJLM7EDP7To0DyDp0TWaFk4V9YUxJVs9NRRv_7-bof9I-Gcc2J/pub?gid=0&single=true&output=csv',
      'https://docs.google.com/spreadsheets/d/e/2PACX-1vStgtzXpQpW_9oWh4QC2NOoO7F9L0fJLM7EDP7To0DyDp0TWaFk4V9YUxJVs9NRRv_7-bof9I-Gcc2J/pub?gid=801564681&single=true&output=csv'
    ];

    const SAMPLE_ROWS = [
      {"DAY Order Date":"Mar 1, 2024","Customer Full name 🔗":"Colorado Springs Scheels","Customer Email 🔗":"orderss@scheels.com","Customer tags":"Wholesale","Order name":"#3384","Order Fulfillment status":"fulfilled","Order Financial status":"paid","Order Total quantity":"24","Total gross sales":"$372.00","Total discounts":"$48.24","Total refunds":"$0.00","Total shipping":"$0.00","Total taxes":"$0.00","Total sales":"$323.76"},
      {"DAY Order Date":"Mar 5, 2024","Customer Full name 🔗":"Ballparks of America","Customer Email 🔗":"","Customer tags":"Wholesale","Order name":"#3385","Order Fulfillment status":"fulfilled","Order Financial status":"paid","Order Total quantity":"286","Total gross sales":"$7,192.52","Total discounts":"$0.00","Total refunds":"$0.00","Total shipping":"$0.00","Total taxes":"$0.00","Total sales":"$7,192.52"},
      {"DAY Order Date":"Nov 10, 2023","Customer Full name 🔗":"Open Balance Customer","Customer Email 🔗":"ar@example.com","Customer tags":"Wholesale","Order name":"#5550","Order Fulfillment status":"fulfilled","Order Financial status":"pending","Order Total quantity":"9","Total gross sales":"$950.00","Total discounts":"$0.00","Total refunds":"$0.00","Total shipping":"$0.00","Total taxes":"$0.00","Total sales":"$950.00"},
      {"DAY Order Date":"Sep 15, 2023","Customer Full name 🔗":"Late Balance Co","Customer Email 🔗":"late@example.com","Customer tags":"Wholesale","Order name":"#4120","Order Fulfillment status":"fulfilled","Order Financial status":"pending","Order Total quantity":"15","Total gross sales":"$1,820.00","Total discounts":"$0.00","Total refunds":"$0.00","Total shipping":"$0.00","Total taxes":"$0.00","Total sales":"$1,820.00"}
    ];

    const state = { rows: [], filteredRows: [], customerRollup: [], view: 'rollup' };

    const els = {
      asOfDate: document.getElementById('asOfDate'),
      dateField: document.getElementById('dateField'),
      refreshBtn: document.getElementById('refreshBtn'),
      exportBtn: document.getElementById('exportBtn'),
      statusText: document.getElementById('statusText'),
      viewRollupBtn: document.getElementById('viewRollupBtn'),
      viewOrdersBtn: document.getElementById('viewOrdersBtn'),
      searchInput: document.getElementById('searchInput'),
      startDate: document.getElementById('startDate'),
      endDate: document.getElementById('endDate'),
      financialFilter: document.getElementById('financialFilter'),
      agingFilter: document.getElementById('agingFilter'),
      rowCount: document.getElementById('rowCount'),
      mainTableTitle: document.getElementById('mainTableTitle'),
      mainTableSub: document.getElementById('mainTableSub'),
      mainHead: document.getElementById('mainHead'),
      mainBody: document.getElementById('mainBody'),
      detailHead: document.getElementById('detailHead'),
      detailBody: document.getElementById('detailBody'),
      companySummary: document.getElementById('companySummary'),
      topCustomers: document.getElementById('topCustomers'),
      agingCards: document.getElementById('agingCards'),
      kpiNetSales: document.getElementById('kpiNetSales'),
      kpiOpenBalance: document.getElementById('kpiOpenBalance'),
      kpiPaidSales: document.getElementById('kpiPaidSales'),
      kpiCustomers: document.getElementById('kpiCustomers'),
      kpi0to30: document.getElementById('kpi0to30'),
      kpi31plus: document.getElementById('kpi31plus')
    };

    function init() {
      const now = new Date();
      const iso = now.toISOString().slice(0, 10);
      els.asOfDate.value = iso;
      els.endDate.value = iso;
      wireEvents();
      loadData();
    }

    function wireEvents() {
      els.refreshBtn.addEventListener('click', loadData);
      els.exportBtn.addEventListener('click', exportRollup);
      els.viewRollupBtn.addEventListener('click', () => setView('rollup'));
      els.viewOrdersBtn.addEventListener('click', () => setView('orders'));
      [els.asOfDate, els.dateField, els.searchInput, els.startDate, els.endDate, els.financialFilter, els.agingFilter].forEach(el => {
        el.addEventListener('input', refreshAll);
        el.addEventListener('change', refreshAll);
      });
    }

    function setStatus(message, isError = false) {
      els.statusText.textContent = message;
      els.statusText.className = `text-xs ${isError ? 'text-red-600' : 'text-slate-500'}`;
    }

    function setView(view) {
      state.view = view;
      els.viewRollupBtn.classList.toggle('active', view === 'rollup');
      els.viewOrdersBtn.classList.toggle('active', view === 'orders');
      if (view === 'orders') document.getElementById('detailPanel').open = true;
      renderMainTable();
    }

    function cleanNumber(value) {
      if (value == null || value === '') return 0;
      const n = Number(String(value).replace(/[$,()\s]/g, '').replace(/−/g, '-'));
      return Number.isFinite(n) ? n : 0;
    }

    function cleanInt(value) {
      if (value == null || value === '') return 0;
      const n = Number(String(value).replace(/[,\s]/g, ''));
      return Number.isFinite(n) ? n : 0;
    }

    function parseDateFlex(value) {
      if (!value) return null;
      const raw = String(value).trim();
      if (!raw) return null;
      const parsed = new Date(raw);
      if (!isNaN(parsed)) return new Date(parsed.getFullYear(), parsed.getMonth(), parsed.getDate());
      return null;
    }

    function stripTime(date) { return new Date(date.getFullYear(), date.getMonth(), date.getDate()); }
    function formatMoney(value) { return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(value || 0); }
    function formatNumber(value) { return new Intl.NumberFormat('en-US').format(value || 0); }
    function formatShortDate(value) { return value ? new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).format(value) : '—'; }
    function escapeHtml(str) { return String(str ?? '').replace(/[&<>"']/g, m => ({ '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[m])); }
    function normalizeStatus(v) { return String(v || '').trim().toLowerCase(); }

    function detectDateKey(row) {
      const keys = Object.keys(row || {});
      const preferred = ['DAY Order Date', 'Order Date', 'Created at', 'Date'];
      for (const key of preferred) if (keys.includes(key)) return key;
      return keys.find(k => /date/i.test(k)) || null;
    }

    function agingBucket(days, openAmount) {
      if (openAmount <= 0) return 'paid';
      if (days <= 30) return '0-30';
      if (days <= 60) return '31-60';
      if (days <= 90) return '61-90';
      return '90+';
    }

    function normalizeRow(row, sourceIndex) {
      const dateKey = els.dateField.value === 'auto' ? detectDateKey(row) : els.dateField.value;
      const orderDate = parseDateFlex(row[dateKey]);
      const gross = cleanNumber(row['Total gross sales']);
      const discounts = cleanNumber(row['Total discounts']);
      const refunds = cleanNumber(row['Total refunds']);
      const shipping = cleanNumber(row['Total shipping']);
      const taxes = cleanNumber(row['Total taxes']);
      const sales = cleanNumber(row['Total sales']);
      const quantity = cleanInt(row['Order Total quantity']);
      const financialStatus = normalizeStatus(row['Order Financial status']);
      const fulfillment = normalizeStatus(row['Order Fulfillment status']);
      const customer = String(row['Customer Full name 🔗'] || row['Customer Full name'] || 'Unknown Customer').trim() || 'Unknown Customer';
      const email = String(row['Customer Email 🔗'] || row['Customer Email'] || '').trim();
      const tags = String(row['Customer tags'] || '').split(',').map(v => v.trim()).filter(Boolean);

      const openStatuses = new Set(['pending','authorized','partially_paid','partially paid','due','unpaid','open']);
      const paidStatuses = new Set(['paid','partially_refunded','partially refunded']);
      const closedStatuses = new Set(['voided','refunded','expired']);

      let settlementClass = 'other';
      if (openStatuses.has(financialStatus)) settlementClass = 'open';
      else if (paidStatuses.has(financialStatus)) settlementClass = 'paid';
      else if (closedStatuses.has(financialStatus)) settlementClass = 'closed';

      let openAmount = settlementClass === 'open' ? Math.max(0, sales) : 0;
      if (sales <= 0) openAmount = 0;
      if (refunds >= Math.max(gross, sales) && Math.max(gross, sales) > 0) openAmount = 0;

      return {
        sourceIndex,
        orderDate,
        customer,
        email,
        tags,
        tagsLabel: tags.join(', '),
        orderName: String(row['Order name'] || '').trim(),
        fulfillment,
        financialStatus,
        settlementClass,
        quantity,
        gross,
        discounts,
        refunds,
        shipping,
        taxes,
        sales,
        openAmount,
        paidAmount: settlementClass === 'paid' ? Math.max(0, sales) : 0,
        ageDays: 0,
        agingBucket: 'paid'
      };
    }

    async function parseCsv(url) {
      return new Promise((resolve, reject) => {
        Papa.parse(url, {
          download: true,
          header: true,
          skipEmptyLines: true,
          complete: results => resolve(results.data || []),
          error: err => reject(err)
        });
      });
    }

    async function loadData() {
      els.refreshBtn.disabled = true;
      setStatus(`Loading ${CSV_SOURCES.length} source${CSV_SOURCES.length === 1 ? '' : 's'}...`);
      try {
        const all = [];
        for (let i = 0; i < CSV_SOURCES.length; i++) {
          const rows = await parseCsv(CSV_SOURCES[i]);
          rows.forEach(r => all.push(normalizeRow(r, i + 1)));
        }
        state.rows = all.filter(r => r.customer || r.orderName);
        refreshAll();
        setStatus(`Loaded ${formatNumber(state.rows.length)} orders.`);
      } catch (err) {
        console.error(err);
        state.rows = SAMPLE_ROWS.map((r, i) => normalizeRow(r, i + 1));
        refreshAll();
        setStatus('Live source failed, showing sample data instead.', true);
      } finally {
        els.refreshBtn.disabled = false;
      }
    }

    function refreshAll() {
      const asOf = parseDateFlex(els.asOfDate.value) || new Date();
      state.rows.forEach(r => {
        if (!r.orderDate || r.openAmount <= 0) {
          r.ageDays = 0;
          r.agingBucket = 'paid';
        } else {
          r.ageDays = Math.max(0, Math.floor((stripTime(asOf) - stripTime(r.orderDate)) / 86400000));
          r.agingBucket = agingBucket(r.ageDays, r.openAmount);
        }
      });

      const q = els.searchInput.value.trim().toLowerCase();
      const start = parseDateFlex(els.startDate.value);
      const end = parseDateFlex(els.endDate.value);
      const financial = els.financialFilter.value;
      const aging = els.agingFilter.value;

      state.filteredRows = state.rows.filter(r => {
        if (q) {
          const hay = [r.customer, r.email, r.orderName, r.tagsLabel, r.financialStatus].join(' ').toLowerCase();
          if (!hay.includes(q)) return false;
        }
        if (start && (!r.orderDate || stripTime(r.orderDate) < stripTime(start))) return false;
        if (end && (!r.orderDate || stripTime(r.orderDate) > stripTime(end))) return false;
        if (financial === 'open' && r.openAmount <= 0) return false;
        if (financial && financial !== 'open' && r.financialStatus !== financial) return false;
        if (aging && r.agingBucket !== aging) return false;
        return true;
      });

      state.customerRollup = rollupCustomers(state.filteredRows);
      renderKpis();
      renderCompanySummary();
      renderTopCustomers();
      renderAgingCards();
      renderMainTable();
      renderDetailTable();
    }

    function rollupCustomers(rows) {
      const map = new Map();
      rows.forEach(r => {
        const key = `${r.customer}__${r.email}`;
        if (!map.has(key)) {
          map.set(key, { customer: r.customer, email: r.email, orders: 0, openOrders: 0, sales: 0, openBalance: 0, b0: 0, b31: 0, b61: 0, b90: 0, oldestOpenDate: null });
        }
        const item = map.get(key);
        item.orders += 1;
        item.sales += r.sales;
        item.openBalance += r.openAmount;
        if (r.openAmount > 0) item.openOrders += 1;
        if (r.openAmount > 0 && r.orderDate && (!item.oldestOpenDate || r.orderDate < item.oldestOpenDate)) item.oldestOpenDate = r.orderDate;
        if (r.agingBucket === '0-30') item.b0 += r.openAmount;
        else if (r.agingBucket === '31-60') item.b31 += r.openAmount;
        else if (r.agingBucket === '61-90') item.b61 += r.openAmount;
        else if (r.agingBucket === '90+') item.b90 += r.openAmount;
      });
      return Array.from(map.values()).sort((a,b) => b.openBalance - a.openBalance || b.sales - a.sales || a.customer.localeCompare(b.customer));
    }

    function renderKpis() {
      const netSales = state.filteredRows.reduce((s, r) => s + r.sales, 0);
      const openBalance = state.filteredRows.reduce((s, r) => s + r.openAmount, 0);
      const paidSales = state.filteredRows.reduce((s, r) => s + r.paidAmount, 0);
      const openCustomers = state.customerRollup.filter(c => c.openBalance > 0).length;
      const b0 = state.filteredRows.filter(r => r.agingBucket === '0-30').reduce((s, r) => s + r.openAmount, 0);
      const b31plus = state.filteredRows.filter(r => ['31-60','61-90','90+'].includes(r.agingBucket)).reduce((s, r) => s + r.openAmount, 0);
      els.kpiNetSales.textContent = formatMoney(netSales);
      els.kpiOpenBalance.textContent = formatMoney(openBalance);
      els.kpiPaidSales.textContent = formatMoney(paidSales);
      els.kpiCustomers.textContent = formatNumber(openCustomers);
      els.kpi0to30.textContent = formatMoney(b0);
      els.kpi31plus.textContent = formatMoney(b31plus);
    }

    function renderCompanySummary() {
      const totalOrders = state.filteredRows.length;
      const openOrders = state.filteredRows.filter(r => r.openAmount > 0).length;
      const gross = state.filteredRows.reduce((s, r) => s + r.gross, 0);
      const discounts = state.filteredRows.reduce((s, r) => s + r.discounts, 0);
      const refunds = state.filteredRows.reduce((s, r) => s + r.refunds, 0);
      const sales = state.filteredRows.reduce((s, r) => s + r.sales, 0);
      const openBalance = state.filteredRows.reduce((s, r) => s + r.openAmount, 0);
      const openPct = sales > 0 ? (openBalance / sales) * 100 : 0;
      const items = [
        ['Orders', formatNumber(totalOrders), `${formatNumber(openOrders)} open`],
        ['Open %', `${openPct.toFixed(1)}%`, 'Of sales'],
        ['Gross', formatMoney(gross), 'Before discounts'],
        ['Net', formatMoney(sales), 'After discounts'],
        ['Disc + ref', formatMoney(discounts + refunds), 'Combined'],
        ['Open bal', formatMoney(openBalance), 'Current']
      ];
      els.companySummary.innerHTML = items.map(([label, value, sub]) => `
        <div class="mini-card">
          <div class="label">${escapeHtml(label)}</div>
          <div class="value mono">${escapeHtml(value)}</div>
          <div class="mt-1 text-xs text-slate-500">${escapeHtml(sub)}</div>
        </div>`).join('');
    }

    function renderTopCustomers() {
      const rows = state.customerRollup.filter(c => c.openBalance > 0).slice(0, 8);
      els.topCustomers.innerHTML = rows.length ? rows.map(c => `
        <div class="list-row">
          <div class="min-w-0">
            <div class="truncate font-semibold text-slate-900">${escapeHtml(c.customer)}</div>
            <div class="text-xs text-slate-500">${formatNumber(c.openOrders)} open</div>
          </div>
          <div class="text-right font-extrabold mono text-slate-900">${formatMoney(c.openBalance)}</div>
        </div>`).join('') : '<div class="text-sm text-slate-500">No open customers.</div>';
    }

    function renderAgingCards() {
      const buckets = [
        ['0–30', state.filteredRows.filter(r => r.agingBucket === '0-30').reduce((s, r) => s + r.openAmount, 0)],
        ['31–60', state.filteredRows.filter(r => r.agingBucket === '31-60').reduce((s, r) => s + r.openAmount, 0)],
        ['61–90', state.filteredRows.filter(r => r.agingBucket === '61-90').reduce((s, r) => s + r.openAmount, 0)],
        ['90+', state.filteredRows.filter(r => r.agingBucket === '90+').reduce((s, r) => s + r.openAmount, 0)]
      ];
      const total = buckets.reduce((s, [,v]) => s + v, 0);
      els.agingCards.innerHTML = buckets.map(([label, value]) => {
        const pct = total > 0 ? (value / total) * 100 : 0;
        return `
          <div class="list-row">
            <div class="flex-1 min-w-0">
              <div class="font-semibold text-slate-900">${label}</div>
              <div class="bar-track"><span class="bar-fill" style="width:${pct}%"></span></div>
            </div>
            <div class="text-right">
              <div class="font-extrabold mono text-slate-900">${formatMoney(value)}</div>
              <div class="text-xs text-slate-500">${pct.toFixed(1)}%</div>
            </div>
          </div>`;
      }).join('');
    }

    function renderMainTable() {
      if (state.view === 'rollup') renderRollupTable();
      else renderOrdersTable();
    }

    function renderRollupTable() {
      els.mainTableTitle.textContent = 'Customer rollup';
      els.mainTableSub.textContent = 'Who owes and how old it is.';
      els.rowCount.textContent = formatNumber(state.customerRollup.length);
      els.mainHead.innerHTML = `<tr>
        <th class="w-customer">Customer</th>
        <th class="w-email">Email</th>
        <th class="right w-small">Ord</th>
        <th class="right w-small">Open</th>
        <th class="right w-money">Sales</th>
        <th class="right w-money">Balance</th>
        <th class="right w-money">0–30</th>
        <th class="right w-money">31–60</th>
        <th class="right w-money">61–90</th>
        <th class="right w-money">90+</th>
        <th class="w-small">Oldest</th>
      </tr>`;
      els.mainBody.innerHTML = state.customerRollup.map(c => `
        <tr>
          <td class="w-customer"><div class="font-semibold text-slate-900">${escapeHtml(c.customer)}</div></td>
          <td class="muted w-email">${escapeHtml(c.email || '—')}</td>
          <td class="right mono w-small">${formatNumber(c.orders)}</td>
          <td class="right mono w-small">${formatNumber(c.openOrders)}</td>
          <td class="right mono w-money">${formatMoney(c.sales)}</td>
          <td class="right mono w-money font-extrabold">${formatMoney(c.openBalance)}</td>
          <td class="right mono w-money">${formatMoney(c.b0)}</td>
          <td class="right mono w-money">${formatMoney(c.b31)}</td>
          <td class="right mono w-money">${formatMoney(c.b61)}</td>
          <td class="right mono w-money">${formatMoney(c.b90)}</td>
          <td class="muted w-small">${c.oldestOpenDate ? formatShortDate(c.oldestOpenDate) : '—'}</td>
        </tr>`).join('') || `<tr><td colspan="11" class="py-10 text-center text-slate-500">No customers match the current filters.</td></tr>`;
    }

    function finBadge(status, openAmount) {
      const s = normalizeStatus(status);
      if (openAmount > 0) return '<span class="badge badge-open">Open</span>';
      if (s === 'paid' || s.includes('refunded')) return '<span class="badge badge-paid">Paid</span>';
      if (s === 'voided' || s === 'expired') return '<span class="badge badge-closed">Closed</span>';
      return `<span class="badge badge-closed">${escapeHtml(s || 'other')}</span>`;
    }

    function fulfillBadge(status) {
      const s = normalizeStatus(status);
      if (s.includes('fulfilled')) return '<span class="badge badge-fulfilled">Fulfilled</span>';
      return '<span class="badge badge-unfulfilled">Unfulfilled</span>';
    }

    function renderOrdersTable() {
      els.mainTableTitle.textContent = 'Orders';
      els.mainTableSub.textContent = 'Underlying rows.';
      els.rowCount.textContent = formatNumber(state.filteredRows.length);
      els.mainHead.innerHTML = `<tr>
        <th class="w-small">Date</th>
        <th class="w-customer">Customer</th>
        <th class="w-small">Order</th>
        <th class="w-small">Fin</th>
        <th class="w-small">Fulfill</th>
        <th class="right w-small">Qty</th>
        <th class="right w-money">Sales</th>
        <th class="right w-money">Open</th>
        <th class="right w-small">Age</th>
      </tr>`;
      els.mainBody.innerHTML = state.filteredRows.slice().sort((a,b) => (b.openAmount - a.openAmount) || ((a.orderDate || 0) - (b.orderDate || 0))).map(r => `
        <tr>
          <td class="muted w-small">${r.orderDate ? formatShortDate(r.orderDate) : '—'}</td>
          <td class="w-customer"><div class="font-semibold text-slate-900">${escapeHtml(r.customer)}</div><div class="text-xs text-slate-500">${escapeHtml(r.email || 'No email')}</div></td>
          <td class="font-semibold text-slate-900 w-small">${escapeHtml(r.orderName || '—')}</td>
          <td class="w-small">${finBadge(r.financialStatus, r.openAmount)}</td>
          <td class="w-small">${fulfillBadge(r.fulfillment)}</td>
          <td class="right mono w-small">${formatNumber(r.quantity)}</td>
          <td class="right mono w-money">${formatMoney(r.sales)}</td>
          <td class="right mono w-money font-extrabold">${formatMoney(r.openAmount)}</td>
          <td class="right mono w-small">${r.openAmount > 0 ? formatNumber(r.ageDays) : '—'}</td>
        </tr>`).join('') || `<tr><td colspan="9" class="py-10 text-center text-slate-500">No orders match the current filters.</td></tr>`;
    }

    function renderDetailTable() {
      els.detailHead.innerHTML = `<tr>
        <th class="w-small">Date</th>
        <th class="w-customer">Customer</th>
        <th class="w-small">Order</th>
        <th class="w-small">Fin</th>
        <th class="w-small">Fulfill</th>
        <th class="right w-small">Qty</th>
        <th class="right w-money">Sales</th>
        <th class="right w-money">Open</th>
        <th class="right w-small">Age</th>
      </tr>`;
      els.detailBody.innerHTML = state.filteredRows.slice().sort((a,b) => (b.openAmount - a.openAmount) || ((a.orderDate || 0) - (b.orderDate || 0))).map(r => `
        <tr>
          <td class="muted w-small">${r.orderDate ? formatShortDate(r.orderDate) : '—'}</td>
          <td class="w-customer"><div class="font-semibold text-slate-900">${escapeHtml(r.customer)}</div><div class="text-xs text-slate-500">${escapeHtml(r.email || 'No email')}</div></td>
          <td class="font-semibold text-slate-900 w-small">${escapeHtml(r.orderName || '—')}</td>
          <td class="w-small">${finBadge(r.financialStatus, r.openAmount)}</td>
          <td class="w-small">${fulfillBadge(r.fulfillment)}</td>
          <td class="right mono w-small">${formatNumber(r.quantity)}</td>
          <td class="right mono w-money">${formatMoney(r.sales)}</td>
          <td class="right mono w-money font-extrabold">${formatMoney(r.openAmount)}</td>
          <td class="right mono w-small">${r.openAmount > 0 ? formatNumber(r.ageDays) : '—'}</td>
        </tr>`).join('') || `<tr><td colspan="9" class="py-10 text-center text-slate-500">No order rows match the current filters.</td></tr>`;
    }

    function exportRollup() {
      const rows = state.customerRollup.map(c => ({
        Customer: c.customer,
        Email: c.email,
        Orders: c.orders,
        Open_Orders: c.openOrders,
        Sales: c.sales.toFixed(2),
        Open_Balance: c.openBalance.toFixed(2),
        Aging_0_30: c.b0.toFixed(2),
        Aging_31_60: c.b31.toFixed(2),
        Aging_61_90: c.b61.toFixed(2),
        Aging_90_plus: c.b90.toFixed(2),
        Oldest_Open_Date: c.oldestOpenDate ? formatShortDate(c.oldestOpenDate) : ''
      }));
      if (!rows.length) return setStatus('Nothing to export for the current view.', true);
      const csv = Papa.unparse(rows);
      const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'statement_rollup.csv';
      a.click();
      URL.revokeObjectURL(url);
      setStatus('Exported current rollup.');
    }

    init();
  </script>
</body>
</html>
